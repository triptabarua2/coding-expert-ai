# Database
DATABASE_URL=mysql://user:password@localhost:3306/coding_expert

# Session
JWT_SECRET=change-me-to-a-long-random-string

# LLM Provider (Choose one)

# Option A: Forge API (Default)
BUILT_IN_FORGE_API_KEY=your-forge-api-key
BUILT_IN_FORGE_API_URL=https://forge.manus.im

# Option B: OpenRouter (If you want to use OpenRouter, update model IDs in shared/models.ts)
# OPENROUTER_API_KEY=your-openrouter-key
# BUILT_IN_FORGE_API_URL=https://openrouter.ai/api

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: Manus OAuth (legacy)
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=

# Optional
# PORT=3000
